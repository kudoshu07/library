NOTE_RSS_URL=
NEXT_PUBLIC_SITE_URL=
IG_BUSINESS_USERNAME=
IG_PHOTO_USERNAME=
INSTAGRAM_FETCH_LIMIT=12

# Instagram Graph API (official). Works for professional accounts (Business/Creator) connected to a Facebook Page.
# Set these on Vercel to fetch Instagram content reliably.
INSTAGRAM_GRAPH_ACCESS_TOKEN=
INSTAGRAM_GRAPH_BUSINESS_IG_USER_ID=
INSTAGRAM_GRAPH_PHOTO_IG_USER_ID=
INSTAGRAM_GRAPH_API_VERSION=v24.0

# Newsletter (Supabase + Resend)
# Supabase project URL (https://xxxxxxxx.supabase.co)
SUPABASE_URL=
# Supabase service role key — used by Next.js API routes (server-only) and the
# GitHub Actions notification script. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=
# From address for outgoing emails (must be verified on Resend)
NEWSLETTER_FROM_EMAIL="Kudo Shu Library <newsletter@example.com>"
# Reply-to address shown to recipients
NEWSLETTER_REPLY_TO=

# Slack Incoming Webhook URL — used to notify on newsletter signups & new comments.
# Create one at https://api.slack.com/messaging/webhooks and paste the URL here.
SLACK_WEBHOOK_URL=

# Cloudflare Turnstile — bot protection on the subscribe and comment forms.
# Both keys are optional; if either is unset the protection is silently skipped
# so the site keeps working while you provision them.
# Get a sitekey/secret pair at https://dash.cloudflare.com -> Turnstile -> Add site.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Blog admin (owner-only authoring UI)
# The single email that can use /admin/blog/* (create, edit, publish posts).
# Anyone else hitting those routes gets a 404.
OWNER_EMAIL=
# GitHub Fine-grained Personal Access Token with Contents: Read & Write
# on the kudoshu07/library repo. See docs/blog-authoring.md for setup.
# Required for publishing posts and uploading images via the editor UI.
GITHUB_TOKEN=
# owner/repo of the GitHub repository the blog is committed to.
GITHUB_REPO=kudoshu07/library
# Branch the editor commits to. Pushing to this branch triggers the Vercel
# build that surfaces the new post (usually 1-2 minutes).
GITHUB_BRANCH=main

